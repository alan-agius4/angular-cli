{
  "pinVersions": false,
  "semanticCommits": true,
  "semanticPrefix": "build",
  "commitMessage": "{{semanticPrefix}} update {{#if groupName}}{{{groupName}}} packages{{else}}{{{depName}}} to version {{{newVersion}}}{{/if}}",
  "separateMajorMinor": false,
  "prHourlyLimit": 5,
  "labels": [
    "PR target: master-only",
    "PR action: merge"
  ],
  "timezone": "America/Tijuana",
  "lockFileMaintenance": {
    "enabled": true
  },
  "baseBranches": [
    "master"
  ],
  "ignoreDeps": [
    "@types/node"
  ],
  "packageFiles": [
    "WORKSPACE",
    "package.json",
    "packages/**/package.json",
    "tests/legacy-cli/e2e/ng-snapshot/package.json"
  ],
  "major": {
    "devDependencies": {
      "enabled": true
    }
  },
  "packageRules": [
    {
      "packagePatterns": [
        "^@angular\/.*"
      ],
      "groupName": "angular",
      "pinVersions": false
    },
   {
      "packagePatterns": [
        "^@babel\/.*"
      ],
      "groupName": "Babel",
      "pinVersions": false
    },
    {
      "packagePatterns": [
        "^@bazel\/.*",
        "^build_bazel.*",
        "^bazel_toolchains$"
      ],
      "groupName": "bazel",
      "pinVersions": false
    },
    {
      "packageNames": [
        "typescript"
      ],
      "separateMinorPatch": true
    },
    {
      "packageNames": [
        "typescript"
      ],
      "updateTypes": [
        "minor",
        "major"
      ],
      "enabled": false
    },
    {
      "depTypeList": ["devDependencies"],
      "updateTypes": ["patch", "minor"],
      "groupName": "devDependencies (non-major)",
      "excludePackagePatterns": [
        "typescript",
        "^@bazel\/.*",
        "^build_bazel.*",
        "^bazel_toolchains$",
        "^@angular\/.*"
      ]
    }
  ]
}
